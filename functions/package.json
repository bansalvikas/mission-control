{
  "name": "hoogle-functions",
  "description": "Cloud Functions for Hoogle — Claude tool-use loop that stores and retrieves items.",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint --ext .js,.ts .",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@vitest/expect": "^4.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "private": true
}
