# Firebase web SDK config — these ARE safe to ship in the client bundle.
# Copy this file to .env.local and fill in values from Firebase console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — region where the Cloud Functions are deployed (default us-central1)
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
